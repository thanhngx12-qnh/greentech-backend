// -----------------------------------------------------------------------------
// File: prisma/schema.prisma
// Chức năng: Thiết kế cấu trúc Database (Bảng, Cột, Khóa ngoại)
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. QUẢN LÝ TÀI KHOẢN & LOG (USERS & AUDIT)
// ==========================================

enum Role {
  SUPER_ADMIN
  EDITOR
  SALES
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String    // Mật khẩu sẽ được mã hóa bcrypt
  full_name  String
  role       Role      @default(EDITOR)
  
  // Chuẩn hóa Timestamps
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime? // Soft Delete

  // Quan hệ 1-N: 1 User có thể có nhiều log
  audit_logs AuditLog[]
  news     News[]

  @@map("users")
}

model AuditLog {
  id            String   @id @default(uuid())
  user_id       String
  action        String   
  module        String   
  record_id     String?  
  old_data      Json?    
  new_data      Json?    
  created_at    DateTime @default(now())

  // Khóa ngoại liên kết tới bảng User
  user          User     @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

// ==========================================
// 2. QUẢN LÝ DANH MỤC ĐA NGÔN NGỮ (CATEGORIES)
// ==========================================

enum CategoryType {
  NEWS       
  SERVICE    
  STANDARD   
}

model Category {
  id         Int          @id @default(autoincrement())
  slug       String       @unique 
  type       CategoryType
  
  // DỮ LIỆU ĐA NGÔN NGỮ JSONB (vi, en, zh)
  name_i18n  Json         
  desc_i18n  Json?        
  seo_i18n   Json?        
  
  // Trạng thái & Sắp xếp
  is_active  Boolean      @default(true)
  order      Int          @default(0)

  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  deleted_at DateTime?

  news     News[]     
  services Service[]

  @@map("categories")
}

// ==========================================
// 3. QUẢN LÝ FORM LIÊN HỆ & KHÁCH HÀNG (LEADS)
// ==========================================

enum LeadStatus {
  NEW         
  CONTACTED   
  QUALIFIED   
  CLOSED      
}

model Lead {
  id            String     @id @default(uuid())
  full_name     String
  email         String
  phone         String?
  company_name  String?
  content       String     @db.Text
  
  status        LeadStatus @default(NEW)
  consent_email Boolean    @default(false) 
  
  // Tracking & UTM
  utm_source    String?
  utm_medium    String?
  utm_campaign  String?
  referrer      String?
  lead_score    Int        @default(0)

  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@map("leads")
}


// ==========================================
// 4. QUẢN LÝ NỘI DUNG (NEWS & SERVICES)
// ==========================================

enum NewsStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  SCHEDULED
}

enum ServiceStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

model News {
  id            String      @id @default(uuid())
  category_id   Int
  author_id     String?     // Người viết bài (liên kết tới User)
  
  // Nội dung đa ngôn ngữ
  slug_i18n     Json        // {"vi": "slug-vi", "en": "slug-en", "zh": "slug-zh"}
  title_i18n    Json        // {"vi": "Tiêu đề", "en": "Title", "zh": "标题"}
  content_i18n  Json        // {"vi": "Nội dung...", "en": "Content...", "zh": "内容..."}
  
  // Hình ảnh
  featured_image String?    // URL ảnh đại diện từ MinIO

  // SEO SUITE (Cực mạnh - Đa ngôn ngữ)
  // Cấu trúc: {"vi": {"meta_title": "...", "og_image": "...", "seo_keywords": "..."}, "en": {...}}
  seo_i18n      Json?       

  // Trạng thái & Quản lý
  status        NewsStatus  @default(DRAFT)
  published_at  DateTime?
  
  // Timestamps
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  deleted_at    DateTime?

  // Quan hệ
  category      Category    @relation(fields: [category_id], references: [id])
  author        User?       @relation(fields: [author_id], references: [id])

  @@map("news")
}

model Service {
  id            String      @id @default(uuid())
  category_id   Int
  
  // Nội dung đa ngôn ngữ
  slug_i18n     Json
  name_i18n     Json
  desc_i18n     Json        // Mô tả ngắn/dài

  // Hình ảnh
  featured_image String?

  // SEO SUITE
  seo_i18n      Json?

  // Trạng thái & Quản lý
  status        ServiceStatus @default(DRAFT)
  
  // Timestamps
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  deleted_at    DateTime?

  // Quan hệ
  category      Category    @relation(fields: [category_id], references: [id])

  @@map("services")
}