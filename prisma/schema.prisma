// -----------------------------------------------------------------------------
// File: prisma/schema.prisma
// Chức năng: Thiết kế cấu trúc Database (Bảng, Cột, Khóa ngoại)
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. QUẢN LÝ TÀI KHOẢN & LOG (USERS & AUDIT)
// ==========================================

enum Role {
  SUPER_ADMIN
  EDITOR
  SALES
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String    // Mật khẩu sẽ được mã hóa bcrypt
  full_name  String
  role       Role      @default(EDITOR)
  
  // Chuẩn hóa Timestamps
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime? // Soft Delete

  // Quan hệ 1-N: 1 User có thể có nhiều log
  audit_logs AuditLog[]
  news     News[]
  services Service[]
  jobs     Job[]
  standards Standard[]

  @@map("users")
}

model AuditLog {
  id            String   @id @default(uuid())
  user_id       String
  action        String   
  module        String   
  record_id     String?  
  old_data      Json?    
  new_data      Json?    
  created_at    DateTime @default(now())

  // Khóa ngoại liên kết tới bảng User
  user          User     @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

// ==========================================
// 2. QUẢN LÝ DANH MỤC ĐA NGÔN NGỮ (CATEGORIES)
// ==========================================

enum CategoryType {
  NEWS       
  SERVICE    
  STANDARD
  JOB
}

model Category {
  id         Int          @id @default(autoincrement())
  slug       String       @unique 
  type       CategoryType
  
  // DỮ LIỆU ĐA NGÔN NGỮ JSONB (vi, en, zh)
  name_i18n  Json         
  desc_i18n  Json?        
  seo_i18n   Json?        
  
  // Trạng thái & Sắp xếp
  is_active  Boolean      @default(true)
  order      Int          @default(0)

  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  deleted_at DateTime?

  news     News[]     
  services Service[]
  jobs     Job[] 
  standards Standard[]

  @@map("categories")
}

// ==========================================
// 3. QUẢN LÝ FORM LIÊN HỆ & KHÁCH HÀNG (LEADS) - ĐÃ CẬP NHẬT
// ==========================================

enum LeadStatus {
  NEW         // Mới gửi
  CONTACTED   // Đã liên hệ
  QUALIFIED   // Khách hàng tiềm năng
  CLOSED      // Đóng/Hoàn thành
}

model Lead {
  id            String     @id @default(uuid())
  full_name     String
  email         String
  phone         String?
  company_name  String?
  content       String     @db.Text
  
  status        LeadStatus @default(NEW)
  consent_email Boolean    @default(false) // Khách tick chọn đồng ý nhận email
  
  // Tracking & UTM (Yêu cầu từ Checklist)
  utm_source    String?
  utm_medium    String?
  utm_campaign  String?
  referrer      String?
  lead_score    Int        @default(0)

  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@map("leads")
}

// ==========================================
// 4. QUẢN LÝ NỘI DUNG (NEWS & SERVICES)
// ==========================================

enum NewsStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  SCHEDULED
}

model News {
  id            String      @id @default(uuid())
  category_id   Int
  author_id     String?     // Liên kết tới User (Người viết bài)
  
  // 1. Nội dung đa ngôn ngữ (JSONB)
  // Chúng ta dùng format: { "vi": "...", "en": "...", "zh": "..." }
  slug_i18n     Json        // URL thân thiện: {"vi": "tin-moi", "en": "new-news", "zh": "..."}
  title_i18n    Json        // Tiêu đề: {"vi": "Tiêu đề", "en": "Title", "zh": "..."}
  content_i18n  Json        // Nội dung: {"vi": "Nội dung...", "en": "Content...", "zh": "..."}

  // 2. Hình ảnh & Media
  featured_image String?    // URL ảnh đại diện chính (từ MinIO)

  // 3. SEO SUITE (Siêu chi tiết - JSONB)
  // Mỗi ngôn ngữ sẽ có một object SEO riêng biệt
  // Cấu trúc: {"vi": {"meta_title": "...", "meta_description": "...", "keywords": "...", "og_image": "..."}, "en": {...}}
  seo_i18n      Json?       

  // 4. Trạng thái & Lập lịch
  status        NewsStatus  @default(DRAFT)
  published_at  DateTime?   // Thời điểm bài viết được phép hiển thị

  // 5. Timestamps
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  deleted_at    DateTime?   // Soft delete

  // QUAN HỆ (RELATIONS)
  category      Category    @relation(fields: [category_id], references: [id])
  author        User?       @relation(fields: [author_id], references: [id])

  @@map("news")
}
// -----------------------------------------------------------------------------
// Bổ sung/Cập nhật Model Service (Chuẩn bị cho cả TinyMCE và SEO)
// -----------------------------------------------------------------------------

model Service {
  id            String      @id @default(uuid())
  category_id   Int
  author_id     String?     // Người quản lý dịch vụ

  // 1. NỘI DUNG ĐA NGÔN NGỮ (Core Content)
  slug_i18n     Json        // {"vi": "phân-tích-nước", "en": "water-analysis", ...}
  title_i18n    Json        // {"vi": "Phân tích nước", "en": "Water Analysis", ...}
  content_i18n  Json        // {"vi": "Nội dung chi tiết...", "en": "...", "zh": "..."}

  // 2. DỮ LIỆU THƯƠNG MẠI (Commercial Data) - Quan trọng cho B2B
  price         Decimal?    @db.Decimal(18, 2) // Dùng Decimal thay vì Float để tránh lỗi làm tròn tiền
  currency      String?     @default("VND")   // Đơn vị tiền tệ (VND, USD, EUR...)
  duration      String?     // Thời gian hoàn thành (vd: "3-5 working days", "24 hours")

  // 3. HÌNH ẢNH & SEO
  featured_image String?
  seo_i18n      Json?       // {"vi": {"meta_title": "...", "og_image": "..."}, "en": {...}}

  // 4. TRẠNG THÁI & QUẢN LÝ
  status        ServiceStatus @default(DRAFT)
  is_active     Boolean       @default(true)
  
  // 5. TIMESTAMPS
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  deleted_at    DateTime?

  // QUAN HỆ
  category      Category      @relation(fields: [category_id], references: [id])
  author        User?         @relation(fields: [author_id], references: [id])

  @@map("services")
}

enum ServiceStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

// 2. Thêm Enum JobType (Hình thức làm việc)
enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERN
}

// 3. Thêm Enum JobStatus
enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

// 6. MODEL JOB (Tin tuyển dụng)
model Job {
  id                String      @id @default(uuid())
  category_id       Int
  author_id         String      // Người tạo tin

  // Nội dung đa ngôn ngữ
  slug_i18n         Json        // {"vi": "ky-su-moi-truong", "en": "environmental-engineer"}
  title_i18n        Json        // {"vi": "Kỹ sư môi trường", "en": "..."}
  description_i18n  Json        // Nội dung mô tả (HTML)
  requirements_i18n Json        // Yêu cầu công việc (HTML)
  benefits_i18n     Json        // Quyền lợi (HTML)

  // Thông tin vật lý
  type              JobType     @default(FULL_TIME) // <--- MỚI: Hình thức làm việc
  location          String      // Địa điểm (VD: Hà Nội, Hồ Chí Minh)
  salary_range      String?     // Khoảng lương (VD: 15-20 triệu)
  deadline          DateTime?   // Hạn nộp hồ sơ

  // Quản trị & SEO
  status            JobStatus   @default(DRAFT)
  seo_i18n          Json?       // SEO Suite
  
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt
  deleted_at        DateTime?

  // QUAN HỆ
  category          Category    @relation(fields: [category_id], references: [id])
  author            User        @relation(fields: [author_id], references: [id])
  applications      JobApplication[]

  @@map("jobs")
}

// 7. MODEL JOB_APPLICATION (Hồ sơ ứng viên - Dùng cho Giai đoạn 2)
model JobApplication {
  id              String    @id @default(uuid())
  job_id          String
  
  full_name       String
  email           String
  phone           String
  cv_url          String    // Link file CV trên Cloudinary
  message         String?   @db.Text
  
  status          String    @default("NEW") // NEW, REVIEWING, INTERVIEW, REJECTED, HIRED
  
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  job             Job       @relation(fields: [job_id], references: [id])

  @@map("job_applications")
}

// ==========================================
// 6. MODULE TÌM KIẾM & THỐNG KÊ (SEARCH LOGS)
// ==========================================

model SearchLog {
  id            String   @id @default(uuid())
  keyword       String   // Từ khóa khách hàng gõ
  lang          String   @default("vi") // Ngôn ngữ lúc tìm kiếm
  results_count Int      @default(0) // Số lượng kết quả tìm thấy (để biết từ khóa nào tìm không ra kết quả)
  created_at    DateTime @default(now())

  @@map("search_logs")
}

// ==========================================
// 7. MODULE SLIDERS (QUẢN LÝ BANNER)
// ==========================================

// Danh sách các vị trí đặt Banner cố định
enum SliderPosition {
  HOME_TOP        // Banner to nhất ở trang chủ
  HOME_MIDDLE     // Banner nằm giữa trang chủ (phần kêu gọi hành động)
  SERVICES_TOP    // Banner ở đầu trang danh sách Dịch vụ
  NEWS_TOP        // Banner ở đầu trang Tin tức
  CONTACT_TOP     // Banner ở trang Liên hệ
}

model Slider {
  id            Int            @id @default(autoincrement())
  name          String         // Tên định danh nội bộ
  position      SliderPosition @default(HOME_TOP)
  
  // 🎯 NÂNG CẤP: Lưu toàn bộ nội dung theo ngôn ngữ vào đây
  // Cấu trúc: { 
  //   "vi": { "image_desktop": "...", "image_mobile": "...", "title": "...", "link": "..." },
  //   "en": { ... }
  // }
  content_i18n  Json  @default("{}") // Thêm giá trị mặc định là một object rỗng

  is_active     Boolean        @default(true)
  order         Int            @default(0)

  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  deleted_at    DateTime?

  @@map("sliders")
}

// ==========================================
// 8. MODULE THƯ VIỆN TIÊU CHUẨN (STANDARDS)
// ==========================================

model Standard {
  id            String      @id @default(uuid())
  category_id   Int
  author_id     String?     // Người đăng tải tài liệu
  
  // Thông tin định danh (Vật lý - để dễ search)
  code          String      @unique // Mã tiêu chuẩn (VD: "QCVN 40:2011/BTNMT")
  
  // Nội dung đa ngôn ngữ
  slug_i18n     Json        // {"vi": "qcvn-40-2011", "en": "..."}
  title_i18n    Json        // {"vi": "Quy chuẩn kỹ thuật quốc gia về nước thải công nghiệp", "en": "..."}
  content_i18n  Json?       // Tóm tắt nội dung tiêu chuẩn (HTML từ TinyMCE)

  // File tài liệu (Lưu link Cloudinary PDF)
  file_url      String?     
  
  // SEO & Quản trị
  seo_i18n      Json?       
  status        NewsStatus  @default(PUBLISHED) // Dùng chung enum với News
  
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  deleted_at    DateTime?

  // QUAN HỆ
  category      Category    @relation(fields: [category_id], references: [id])
  author        User?       @relation(fields: [author_id], references: [id])

  @@map("standards")
}